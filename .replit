modules = ["nodejs-20", "python-3.11"]
[nix]
channel = "stable-25_05"

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["github:1.0.0"]

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3002

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3001

[userenv]

[userenv.shared]
AI_INTEGRATIONS_GEMINI_BASE_URL = "https://generativelanguage.googleapis.com"
NODE_ENV = "development"
PORT = "8080"
ALLOWED_ORIGINS = ""

[postMerge]
path = "bio-study-hub/scripts/post-merge.sh"
timeoutMs = 60000

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "BioSpark Frontend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "BioSpark API"

[[workflows.workflow]]
name = "BioSpark Frontend"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd bio-study-hub/artifacts/biospark && pnpm exec vite --config vite.config.ts --host 0.0.0.0 --port 5000"
waitForPort = 5000

[[workflows.workflow]]
name = "BioSpark API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd bio-study-hub/artifacts/api-server && pnpm exec tsx ./src/index.ts"
waitForPort = 8080
